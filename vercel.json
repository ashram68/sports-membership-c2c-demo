{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/listing/:id((?!_id).*)", "destination": "/listing/_id" },
    { "source": "/chat/:id((?!_id).*)", "destination": "/chat/_id" }
  ]
}
